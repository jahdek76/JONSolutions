<%- include('../partials/header') %>
<h1><%= project._id ? 'Edit' : 'Add' %> Project</h1>
<% if (locals.error) { %>
    <div class="error"><%= error %></div>
<% } %>
<form action="<%= project._id ? `/cms/projects/${project._id}` : '/cms/projects' %>" method="POST">
    <div>
        <label for="title">Title:</label>
        <input type="text" id="title" name="title" value="<%= project.title || '' %>" required>
    </div>
    <div>
        <label for="description">Description:</label>
        <textarea id="description" name="description" required><%= project.description || '' %></textarea>
    </div>
    <div>
        <label for="client">Client:</label>
        <input type="text" id="client" name="client" value="<%= project.client || '' %>" required>
    </div>
    <div>
        <label for="completionDate">Completion Date:</label>
        <input type="date" id="completionDate" name="completionDate" value="<%= project.completionDate ? project.completionDate.toISOString().split('T')[0] : '' %>" required>
    </div>
    <button type="submit" class="btn">Save Project</button>
</form>
<%- include('../partials/footer') %>
